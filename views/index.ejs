<!-- ===== COMPETENCES ===== -->
<section class="section section-alt" id="competences">
  <div class="container">
    <div class="section-head">
      <span class="section-idx">04</span>
      <h2 class="section-title">Compétences techniques</h2>
    </div>

    <div class="skills-grid">
      <% profile.skills.forEach(function(sk){ %>
      <div class="skill-group">
        <h4><%= sk.group %></h4>
        <div class="skill-tags">
          <% sk.items.forEach(function(it){ %><span class="tag tag-mono"><%= it %></span><% }); %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

