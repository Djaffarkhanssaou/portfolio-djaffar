<!-- ===== HERO ===== -->
<header class="hero" id="top">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Portfolio — <%= profile.location %></p>
      <h1 class="hero-title">
        <%= profile.name.split(' ')[0] %><br><%= profile.name.split(' ')[1] %>
      </h1>
      <p class="hero-role"><%= profile.role %></p>
      <p class="hero-tagline"><%= profile.tagline %></p>
      <div class="hero-actions">
        <a href="#projets" class="btn btn-signal">Voir les projets</a>
        <a href="<%= profile.cv %>" class="btn btn-outline-signal" download>Télécharger le CV ↓</a>
      </div>
      <div class="hero-social">
        <a href="<%= profile.linkedin %>" target="_blank" rel="noopener">LinkedIn ↗</a>
        <a href="<%= profile.github %>" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
      <div class="hero-stats">
        <% profile.stats.forEach(function(s){ %>
        <div class="stat">
          <span class="stat-value"><%= s.value %></span>
          <span class="stat-label"><%= s.label %></span>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="hero-visual">
      <div class="terminal" role="img" aria-label="Terminal affichant le profil de <%= profile.name %>">
        <div class="terminal-bar">
          <span class="dot d1"></span><span class="dot d2"></span><span class="dot d3"></span>
          <span class="terminal-title">djaffar@portfolio: ~</span>
        </div>
        <div class="terminal-body" id="terminalBody">
          <div class="photo-frame">
            <img src="<%= profile.photo %>" alt="Photo de <%= profile.name %>">
          </div>
          <p class="tline"><span class="prompt">$</span> whoami</p>
          <p class="tline tout" id="tOut1"></p>
          <p class="tline"><span class="prompt">$</span> cat stack.txt</p>
          <p class="tline tout" id="tOut2"></p>
          <p class="tline"><span class="prompt">$</span> <span class="cursor">▌</span></p>
        </div>
      </div>
    </div>
  </div>
</header>

<main>

<!-- ===== PROFIL ===== -->
<section class="section" id="profil">
  <div class="container">
    <div class="section-head">
      <span class="section-idx">01</span>
      <h2 class="section-title">Profil</h2>
    </div>
    <div class="row">
      <div class="col-lg-8">
        <p class="lede"><%= profile.summary %></p>
      </div>
      <div class="col-lg-4">
        <div class="info-card">
          <p><span class="ic-label">Email</span><a href="mailto:<%= profile.email %>"><%= profile.email %></a></p>
          <p><span class="ic-label">Téléphone</span><a href="tel:<%= profile.phone.replace(/\s/g,'') %>"><%= profile.phone %></a></p>
          <p><span class="ic-label">Localisation</span><span><%= profile.location %></span></p>
          <p><span class="ic-label">Centres d'intérêt</span><span><%= profile.interests.join(' · ') %></span></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== EXPERIENCE (git log style) ===== -->
<section class="section section-alt" id="experience">
  <div class="container">
    <div class="section-head">
      <span class="section-idx">02</span>
      <h2 class="section-title">Expérience</h2>
      <span class="section-note">git log --author="Djaffar" --oneline</span>
    </div>

    <div class="commit-log">
      <% profile.experience.forEach(function(exp, i){ %>
      <article class="commit">
        <div class="commit-marker">
          <span class="commit-dot"></span>
          <% if(i < profile.experience.length - 1){ %><span class="commit-line"></span><% } %>
        </div>
        <div class="commit-body">
          <p class="commit-meta"><%= exp.period %></p>
          <h3 class="commit-title"><%= exp.role %></h3>
          <% if(exp.org){ %><p class="commit-org"><%= exp.org %></p><% } %>
          <ul class="commit-points">
            <% exp.points.forEach(function(p){ %><li><%= p %></li><% }); %>
          </ul>
        </div>
      </article>
      <% }); %>
    </div>
  </div>
</section>

